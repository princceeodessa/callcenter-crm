APP_NAME="Callcenter CRM"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Europe/Samara

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=callcenter_crm
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
TRANSCRIPTION_DRIVER=whisper_cli
TRANSCRIPTION_DISPATCH=after_response
WHISPER_PYTHON=py
WHISPER_SCRIPT=tools/transcribe.py
WHISPER_MODEL=small
WHISPER_LANGUAGE=ru
WHISPER_TIMEOUT=300

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
