APP_NAME="Callcenter CRM"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Europe/Samara

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=callcenter_crm
DB_USERNAME=root
DB_PASSWORD=
DB_SOCKET=
MYSQL_ATTR_SSL_CA=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_COOKIE=callcenter_crm_session
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false
SESSION_CONNECTION=
SESSION_STORE=

CACHE_DRIVER=file
CACHE_PREFIX=callcenter_crm
FILESYSTEM_DISK=local

QUEUE_CONNECTION=database
DB_QUEUE_TABLE=jobs
DB_QUEUE=default
DB_QUEUE_RETRY_AFTER=600
QUEUE_FAILED_DRIVER=database-uuids
QUEUE_FAILED_TABLE=failed_jobs

TRANSCRIPTION_DRIVER=whisper_cli
TRANSCRIPTION_DISPATCH=after_response
TRANSCRIPTION_QUEUE_CONNECTION=database
TRANSCRIPTION_QUEUE=transcription
WHISPER_PYTHON=py
WHISPER_SCRIPT=tools/transcribe.py
WHISPER_MODEL=small
WHISPER_MODEL_DIR=storage/app/whisper-models
WHISPER_LANGUAGE=ru
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_CPU_THREADS=0
WHISPER_NUM_WORKERS=1
WHISPER_BEAM_SIZE=5
WHISPER_TIMEOUT=300

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AVITO_OAUTH_AUTHORIZE_URL=https://www.avito.ru/oauth
AVITO_OAUTH_SCOPE="messenger:read messenger:write"
AVITO_OAUTH_REDIRECT_URI=
